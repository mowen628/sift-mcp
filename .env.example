# Copy to .env and fill in your values — never commit .env

# InfluxDB (sift-ir bucket)
INFLUXDB_URL=http://10.0.0.3:8086
INFLUXDB_TOKEN=your-token-here
INFLUXDB_ORG=your-org
INFLUXDB_BUCKET=sift-ir

# AdGuard Home API
ADGUARD_URL=http://10.0.0.3:3080
ADGUARD_USER=your-username
ADGUARD_PASS=your-password

# Docker host SSH (for container log triage)
DOCKER_HOST_IP=10.0.0.3
DOCKER_HOST_USER=matt-owen
DOCKER_HOST_KEY=~/.ssh/id_ed25519

# Home Assistant webhook (optional — high-severity alerts)
HA_WEBHOOK_URL=

# Case storage
CASES_DIR=/cases
LOGS_DIR=/home/sansforensics/sift-mcp/logs
